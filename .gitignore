# =============================================================================
# Dependencies
# =============================================================================
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.yarn/install-state.gz

# =============================================================================
# Testing
# =============================================================================
coverage/
*.lcov

# =============================================================================
# Next.js (frontend)
# =============================================================================
/frontend/.next/
/frontend/out/
/frontend/.vercel/
/frontend/next-env.d.ts

# =============================================================================
# Backend (Express + TypeScript)
# =============================================================================
/backend/dist/
/backend/build/

# =============================================================================
# Build output (general)
# =============================================================================
/build/

# =============================================================================
# Environment variables (NEVER COMMIT SECRETS)
# =============================================================================
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
!.env.example
!.env.sample
!.env.template

# =============================================================================
# Logs
# =============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/

# =============================================================================
# Cache
# =============================================================================
.eslintcache
.cache/
*.tsbuildinfo

# =============================================================================
# Editor / IDE
# =============================================================================
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project
.history/

# =============================================================================
# Operating system
# =============================================================================
.DS_Store
Thumbs.db
Thumbs.db:encryptable
desktop.ini

# =============================================================================
# Docker
# =============================================================================
docker-compose.override.yml

# =============================================================================
# Misc
# =============================================================================
*.pem
*.key

# =============================================================================
# Terraform
# =============================================================================
# Local state — NEVER commit
*.tfstate
*.tfstate.*
*.tfplan

# Provider/plugin cache (local to each machine)
**/.terraform/

# NOTE: .terraform.lock.hcl SHOULD be committed (like package-lock.json)
# Do NOT ignore it.

# Crash logs
crash.log
crash.*.log

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# Secrets — NEVER COMMIT
*.tfvars
*.auto.tfvars
*.tfvars.json
!*.tfvars.example

# =============================================================================
# Vercel (if deploying frontend separately)
# =============================================================================
.vercel